{
  "_comment": "Template for the conduit (Phorge) MCP server. Copy to .mcp.json at the root of the repo you work in. Claude Code auto-discovers it and prompts each developer to approve. No secrets live here: PHABRICATOR_TOKEN is expanded from each developer's own environment. Set PHABRICATOR_URL to your Phorge instance.",
  "mcpServers": {
    "conduit": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/kyu-n/conduit.git@main",
        "conduit-mcp"
      ],
      "env": {
        "PHABRICATOR_URL": "https://<your-phorge-host>/api/",
        "PHABRICATOR_TOKEN": "${PHABRICATOR_TOKEN}"
      }
    }
  }
}
