# Copy to .env for the docker-compose (public) deployment.

# Public hostname clients connect to. Caddy provisions a TLS cert for it.
CONDUIT_DOMAIN=mcp.example.com
# Contact email for the ACME (Let's Encrypt) account.
ACME_EMAIL=ops@example.com

# Your Phorge/Phabricator API base (note the trailing /api/).
PHABRICATOR_URL=https://phorge.example.com/api/

# DNS-rebinding allowlists. Caddy forwards the client's Host header to conduit,
# so this must include the public domain. Non-browser MCP clients send no
# Origin (those pass); browser clients must send an allowed Origin.
# Matching is exact and INCLUDES any port: a client that sends Host
# "mcp.example.com:443" will not match a bare "mcp.example.com". Use the "host:*"
# wildcard (e.g. mcp.example.com:*) to accept any port.
CONDUIT_ALLOWED_HOSTS=mcp.example.com
CONDUIT_ALLOWED_ORIGINS=https://mcp.example.com

# Read-only is the default in public mode. Set to 0 to expose write tools
# (each user still writes as themselves via their own X-Phabricator-Token).
CONDUIT_READONLY=1

# Optional: identify your deployment to the Phorge operator.
# PHABRICATOR_USER_AGENT=MyOrg-Conduit-MCP/1.0 (ops@example.com)
# Optional: outbound proxy for the Phorge calls.
# PHABRICATOR_PROXY=socks5://127.0.0.1:1080
